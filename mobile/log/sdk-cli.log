  event_type: 'TestRunStarted',
  test_run: {
    type: 'test',
    framework: 'WebdriverIO-mocha',
    uuid: 'ca8957f4-6403-431c-bea7-41ed6b59acdc',
    name: 'S5: Responsive Layout Kontrolu (Her Adım SS)',
    body: {
      lang: 'ecmascript',
      code: 'async () => {\r\n' +
        '    const size = await browser.getWindowSize();\r\n' +
        '    const width = size.width;\r\n' +
        '\r\n' +
        '    await browser.takeProof(`S5_1_Baslangic_${width}px`);\r\n' +
        '\r\n' +
        "    const menuBtn = await $('.bm-burger-button');\r\n" +
        '    await menuBtn.waitForDisplayed({ timeout: 5000 });\r\n' +
        '    \r\n' +
        '    try {\r\n' +
        '        await menuBtn.click();\r\n' +
        '    } catch (e) {\r\n' +
        '        await browser.execute((el) => el.click(), menuBtn);\r\n' +
        '    }\r\n' +
        '    \r\n' +
        '    await browser.pause(2000); \r\n' +
        '    await browser.takeProof(`S5_2_Menu_Acildi_${width}px`);\r\n' +
        '\r\n' +
        "    const closeBtn = await $('#react-burger-cross-btn');\r\n" +
        '    \r\n' +
        '  \r\n' +
        '    await closeBtn.waitForExist({ timeout: 5000 });\r\n' +
        '    \r\n' +
        '    try {\r\n' +
        '        await browser.execute((el) => el.click(), closeBtn);\r\n' +
        '    } catch (e) {\r\n' +
        '        console.log("Normal click başarısız, menü açık kalmış olabilir.");\r\n' +
        '    }\r\n' +
        '    \r\n' +
        '    await browser.pause(1500); \r\n' +
        '    await browser.takeProof(`S5_3_Menu_Kapandi_${width}px`);\r\n' +
        '    \r\n' +
        '    await browser.execute(() => window.scrollTo(0, 500));\r\n' +
        '    await browser.takeProof(`S5_4_Layout_Check_${width}px`);\r\n' +
        '}'
    },
    identifier: 'S5: Responsive Layout Kontrolu (Her Adım SS)',
    scope: 'Senior QA Case Study - Adim Adim İspatli Test Paketi - S5: Responsive Layout Kontrolu (Her Adım SS)',
    scopes: [ 'Senior QA Case Study - Adim Adim İspatli Test Paketi' ],
