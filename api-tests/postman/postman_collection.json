  "item": [
    {
      "name": "TC-API-001: Başarılı Auth (Token Al)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var body = pm.response.json();\r",
              "pm.environment.set(\"authToken\", body.token); // Token'ı diğer testler için kaydeder\r",
              "pm.test(\"Status 200\", () => pm.response.to.have.status(200));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\"username\": \"admin\", \"password\": \"password123\"}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth"
          ]
        }
      },
      "response": []
    },
    {
      "name": "TC-API-006: Yeni Rezervasyon Oluştur",
