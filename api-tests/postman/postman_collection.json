    {
      "name": "TC-API-007: Rezervasyon Güncelle (PUT)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Updated Successfully\", () => {\r",
              "    pm.expect(pm.response.json().firstname).to.eql(\"Master\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Cookie",
            "value": "token={{authToken}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"firstname\": \"Master\",\r\n    \"lastname\": \"QA\",\r\n    \"totalprice\": 150,\r\n    \"depositpaid\": true,\r\n    \"bookingdates\": {\r\n        \"checkin\": \"2026-01-01\",\r\n        \"checkout\": \"2026-01-02\"\r\n    },\r\n    \"additionalneeds\": \"Updated Data\"\r\n}",
