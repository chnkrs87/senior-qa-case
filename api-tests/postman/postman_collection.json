      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Fields are not null\", () => {\r",
              "    var body = pm.response.json();\r",
              "    pm.expect(body.firstname).to.not.be.null;\r",
              "    pm.expect(body.lastname).to.not.be.null;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
