            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "\r",
              "var jsonData = pm.response.json();\r",
              "if (jsonData.bookingid) {\r",
              "    pm.environment.set(\"bookingId\", jsonData.bookingid);\r",
              "    console.log(\"Kaydedilen ID: \" + jsonData.bookingid);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"firstname\": \"Senior\",\r\n    \"lastname\": \"QA\",\r\n    \"totalprice\": 100,\r\n    \"depositpaid\": true,\r\n    \"bookingdates\": {\r\n        \"checkin\": \"2026-01-01\",\r\n        \"checkout\": \"2026-01-02\"\r\n    },\r\n    \"additionalneeds\": \"Initial Data\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
